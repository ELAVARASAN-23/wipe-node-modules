*.tsbuildinfo

# Coverage directory
coverage/

# Environment variables
.env
.env.test
.env.production

# Mac / Linux / Windows system files
.DS_Store
Thumbs.db

# IDEs and editors
.vscode/
.idea/
*.swp
*.swo

# Temporary files
tmp/
temp/

# Package lock files (optional: usually keep ONE)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Test files (optional: exclude if not needed in repo)
test/
tests/
__tests__/

# Docs (optional)
docs/

# Examples (optional)
examples/